# =============================================================================
# FitOS — Environment variables
# =============================================================================
#
# 1. Copy this file to `.env.local` in the project root.
# 2. Replace every placeholder with your own values.
# 3. Never commit `.env.local` or real secrets to git.
#
# Each developer and each deployment (local, staging, production) must use
# their own keys. Do not share production keys in issues, PRs, or chat.
#
# =============================================================================

# --- Public (embedded in the browser bundle) ---
# Safe to use in Client Components. These are NOT secret, but still use your
# own Supabase project — never reuse someone else's project credentials.
#
# Supabase → Project Settings → API
# Paste each value as ONE continuous line (no line breaks inside JWT keys).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Server-only (NEVER prefix with NEXT_PUBLIC_) ---
# Only read these in Server Components, Route Handlers, Server Actions, or
# other server-side code. Import from `@/lib/env.server` — never from client
# components and never expose via API responses.
#
# Supabase → Project Settings → API → service_role (bypasses RLS — keep secret)

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI → https://platform.openai.com/api-keys

OPENAI_API_KEY=your-openai-api-key

# --- Single-user access (server-only) ---
# Only this email may sign in, register, or call protected APIs.
# In Supabase Dashboard → Authentication → Providers, also disable public sign-ups
# after your account is created.

ALLOWED_USER_EMAIL=your-email@example.com
